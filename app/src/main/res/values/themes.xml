<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Vervan" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Phase I — compact floating window for QuickActionActivity (ACTION_PROCESS_TEXT),
         so it appears as a small popup over the host app instead of taking the full screen. -->
    <style name="Theme.Vervan.Dialog" parent="android:Theme.Material.Light.Dialog.NoActionBar">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
